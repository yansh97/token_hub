{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Token Hub (dev)",
  "version": "0.1.159",
  "identifier": "com.yansh97.token-hub.dev",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Token Hub (dev)",
        "width": 1064,
        "height": 658,
        "minWidth": 1064,
        "minHeight": 658,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["kiro"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzRERDQzZFRjM0RTcxQkMKUldTOGNVN3pic3pkUTRZR3VaL3BVd2tUK3RyYys0MWR4akZDaFBCTHU0U2JjcUJwengvOTB0aHkK",
      "endpoints": [
        "https://github.com/yansh97/token_hub/releases/latest/download/latest.json"
      ]
    }
  }
}
